{
  "name": "attention",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "bun server.ts",
    "dev": "vite --host 127.0.0.1",
    "start": "concurrently -k -n api,web -c brown,blue \"bun run api\" \"pnpm dev\"",
    "build": "tsc && vite build",
    "test": "bun test",
    "cli": "bun run cli.ts",
    "seed:demo": "bun run cli.ts demo:seed"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "hono": "^4.10.7",
    "vite": "^7.2.7",
    "typescript": "^5.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  },
  "packageManager": "pnpm@9.15.4"
}
