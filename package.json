{
  "name": "tend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "api": "bun server.ts",
    "web": "bun web.ts",
    "dev": "vite --host 127.0.0.1",
    "start": "bun scripts/dev.ts",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "test": "bun test",
    "seed:demo": "bun tend.ts cli demo:seed",
    "tend": "bun tend.ts",
    "tend:build": "bun scripts/clean-legacy-cli-artifacts.ts && bun build ./tend.ts --compile --outfile dist-bin/tend",
    "tend:smoke": "bun scripts/smoke-binary.ts",
    "tend:package": "bun scripts/clean-legacy-cli-artifacts.ts && bun scripts/package-binary.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "hono": "^4.12.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "oxlint": "^1.68.0",
    "supabase": "2.106.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  },
  "engines": {
    "bun": ">=1.3.11",
    "node": ">=22",
    "pnpm": "9.15.4"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    }
  },
  "bin": {
    "tend": "./tend.ts"
  }
}
